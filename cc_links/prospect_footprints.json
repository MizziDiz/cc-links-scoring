{
  "version": 1,
  "comment": "Common Crawl prospect taxonomy derived from the local A-Parser footprint families. Broad search phrases require corroboration; URL, generator and structural HTML signals carry more weight.",
  "defaults": {
    "minimum_score": 50,
    "minimum_signal_types": 2
  },
  "rules": [
    {
      "id": "wordpress_comment",
      "family": "blog_comment",
      "platform": "WordPress",
      "signals": {
        "generator_contains": ["wordpress"],
        "url_contains": ["wp-comments-post.php", "/comments/feed/"],
        "html_contains": ["wp-comments-post.php", "comment_post_id", "comment-form", "your email address will not be published", "notify me of follow-up comments"]
      }
    },
    {
      "id": "generic_blog_comment",
      "family": "blog_comment",
      "platform": null,
      "signals": {
        "url_contains": ["/comment/", "#respond"],
        "html_contains": ["leave a comment", "post a comment", "comments rss", "name=\"comment\"", "name='comment'", "comment-form"]
      }
    },
    {
      "id": "phpbb_forum",
      "family": "forum",
      "platform": "phpBB",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "generator_contains": ["phpbb"],
        "url_contains": ["viewtopic.php", "viewforum.php", "memberlist.php"],
        "html_contains": ["powered by phpbb", "phpbb"]
      }
    },
    {
      "id": "vbulletin_forum",
      "family": "forum",
      "platform": "vBulletin",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "generator_contains": ["vbulletin"],
        "url_contains": ["showthread.php", "forumdisplay.php", "memberlist.php"],
        "html_contains": ["powered by vbulletin", "vbulletin"]
      }
    },
    {
      "id": "smf_forum",
      "family": "forum",
      "platform": "SMF",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "generator_contains": ["simple machines"],
        "url_contains": ["index.php?action=register", "index.php?topic=", "index.php?board="],
        "html_contains": ["powered by smf", "simple machines forum"]
      }
    },
    {
      "id": "mybb_forum",
      "family": "forum",
      "platform": "MyBB",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "generator_contains": ["mybb"],
        "url_contains": ["showthread.php?tid=", "member.php?action=register"],
        "html_contains": ["powered by mybb", "mybb"]
      }
    },
    {
      "id": "generic_forum",
      "family": "forum",
      "platform": null,
      "signals": {
        "url_contains": ["/forum/", "/forums/", "/threads/", "memberlist.php"],
        "html_contains": ["forum", "register", "member list", "new topic"]
      }
    },
    {
      "id": "guestbook",
      "family": "guestbook",
      "platform": null,
      "signals": {
        "url_contains": ["guestbook", "gbook.php", "signbook.php", "addentry.php"],
        "html_contains": ["sign my guestbook", "add to guestbook", "view guestbook", "guestbook entries", "powered by php guestbook"]
      }
    },
    {
      "id": "article_submission",
      "family": "article_submit",
      "platform": null,
      "signals": {
        "url_contains": ["submit-article", "submit_article", "add-article", "add_article"],
        "html_contains": ["powered by article dashboard", "submit article", "add article", "article directory", "powered by seo-board"]
      }
    },
    {
      "id": "mediawiki",
      "family": "wiki",
      "platform": "MediaWiki",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "generator_contains": ["mediawiki"],
        "url_contains": ["special:createaccount", "special:userlogin", "index.php?title=special:"],
        "html_contains": ["powered by mediawiki", "this page was last edited", "mw-content-text"]
      }
    },
    {
      "id": "pligg_bookmark",
      "family": "social_bookmark",
      "platform": "Pligg",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "generator_contains": ["pligg"],
        "url_contains": ["submit.php", "/upcoming/"],
        "html_contains": ["powered by pligg", "submit a new story", "upcoming news", "published news"]
      }
    },
    {
      "id": "php_link_directory",
      "family": "directory",
      "platform": "PHP Link Directory",
      "signals": {
        "url_contains": ["add-url.php", "submit-link", "submit.php"],
        "html_contains": ["powered by phpld", "powered by php link directory", "submit your site", "add your site", "add a link"]
      }
    },
    {
      "id": "generic_directory",
      "family": "directory",
      "platform": null,
      "signals": {
        "url_contains": ["/directory/", "/submit-site", "/add-listing"],
        "html_contains": ["link directory", "business directory", "submit your link", "submit your site"]
      }
    },
    {
      "id": "coppermine_comment",
      "family": "image_comment",
      "platform": "Coppermine",
      "minimum_score": 30,
      "minimum_signal_types": 1,
      "signals": {
        "url_contains": ["displayimage.php", "addcomment"],
        "html_contains": ["powered by coppermine photo gallery", "coppermine photo gallery"]
      }
    },
    {
      "id": "nukeviet_redirect",
      "family": "redirect_backlink",
      "platform": "NukeViet",
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [["nv_redirect=", "nv="]],
      "signals": {
        "url_all": [["nv_redirect=", "nv="]],
        "html_contains": ["nukeviet", "nv3-content"]
      }
    },
    {
      "id": "bitrix_redirect",
      "family": "redirect_backlink",
      "platform": "Bitrix",
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [
        ["/bitrix/redirect.php", "goto="],
        ["/bitrix/rk.php", "goto="],
        ["/bitrix/click.php", "goto="]
      ],
      "signals": {
        "url_all": [
          ["/bitrix/redirect.php", "goto="],
          ["/bitrix/rk.php", "goto="],
          ["/bitrix/click.php", "goto="]
        ],
        "html_contains": ["1c-bitrix", "bx-core"]
      }
    },
    {
      "id": "google_redirect",
      "family": "redirect_backlink",
      "platform": "Google",
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [
        ["google.", "/url?", "q="],
        ["google.", "/url?", "url="]
      ],
      "signals": {
        "url_all": [
          ["google.", "/url?", "q="],
          ["google.", "/url?", "url="]
        ]
      }
    },
    {
      "id": "generic_external_redirect",
      "family": "redirect_backlink",
      "platform": null,
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [
        ["/redirect.php", "url="],
        ["/redirect.asp", "url="],
        ["/redirect?", "url="],
        ["/go.php", "url="],
        ["/go?http"],
        ["/proxy.php", "link="],
        ["/opener.php", "url="],
        ["/www/delivery/ck.php", "oadest"]
      ],
      "signals": {
        "url_all": [
          ["/redirect.php", "url="],
          ["/redirect.asp", "url="],
          ["/redirect?", "url="],
          ["/go.php", "url="],
          ["/go?http"],
          ["/proxy.php", "link="],
          ["/opener.php", "url="],
          ["/www/delivery/ck.php", "oadest"]
        ]
      }
    },
    {
      "id": "mediawiki_user_page",
      "family": "profile_page",
      "platform": "MediaWiki",
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [
        ["index.php?title=user:"], ["index.php?title=user%3a"],
        ["index.php?title=usuario:"], ["index.php?title=usuario%3a"],
        ["index.php?title=utilisateur:"], ["index.php?title=utilisateur%3a"],
        ["index.php?title=benutzer:"], ["index.php?title=benutzer%3a"]
      ],
      "signals": {
        "url_all": [
          ["index.php?title=user:"], ["index.php?title=user%3a"],
          ["index.php?title=usuario:"], ["index.php?title=usuario%3a"],
          ["index.php?title=utilisateur:"], ["index.php?title=utilisateur%3a"],
          ["index.php?title=benutzer:"], ["index.php?title=benutzer%3a"]
        ],
        "generator_contains": ["mediawiki"],
        "html_contains": ["mw-content-text", "mw-userpage"]
      }
    },
    {
      "id": "bbpress_profile",
      "family": "profile_page",
      "platform": "bbPress",
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [["/forums/users/"]],
      "signals": {
        "url_contains": ["/forums/users/"],
        "html_contains": ["bbpress", "bbp-user-page"]
      }
    },
    {
      "id": "discuz_thread",
      "family": "forum",
      "platform": "Discuz",
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [
        ["forum.php?mod=viewthread"],
        ["viewthread.php?tid="],
        ["/thread-", ".html"]
      ],
      "signals": {
        "url_all": [
          ["forum.php?mod=viewthread"],
          ["viewthread.php?tid="],
          ["/thread-", ".html"]
        ],
        "generator_contains": ["discuz"],
        "html_contains": ["powered by discuz", "discuz!"]
      }
    },
    {
      "id": "generic_board_post",
      "family": "forum",
      "platform": null,
      "minimum_score": 50,
      "minimum_signal_types": 1,
      "discovery": [["/bbs/board.php", "bo_table=", "wr_id="]],
      "signals": {
        "url_all": [["/bbs/board.php", "bo_table=", "wr_id="]],
        "html_contains": ["bo_table", "wr_id"]
      }
    },
    {
      "id": "trackback",
      "family": "trackback",
      "platform": null,
      "signals": {
        "url_contains": ["/trackback/", "wp-trackback.php", "mt-tb.cgi"],
        "html_contains": ["trackback url for this entry", "trackback url", "send trackback", "trackback ping"]
      }
    }
  ]
}

# Host directories mounted into the container. Docker creates them if absent.
DB_HOST_DIR=./data/db
CANDIDATES_HOST_DIR=./data/candidates

# Container paths. Keep writable run artifacts under /data.
PIPELINE_CONFIG=/app/run.config.json
PIPELINE_DB=/data/db/latam.db
PIPELINE_CANDIDATES_FILE=/data/candidates/candidates.jsonl
PIPELINE_CATEGORIES_FILE=/app/categories.json
PIPELINE_PRIORITIES_FILE=
PIPELINE_EXCLUDE_FILE=

# Discovery and fetch settings. Non-empty values override run.config.json.
PIPELINE_CRAWL=CC-MAIN-2026-25
PIPELINE_COUNTRIES=
PIPELINE_PER_CATEGORY_LIMIT=100000
PIPELINE_TOTAL_LIMIT=
PIPELINE_PER_COUNTRY_LIMIT=
PIPELINE_MAX_PER_DOMAIN=300
PIPELINE_MAX_PARTS=
PIPELINE_DISCOVER_DELAY=2
PIPELINE_DISCOVERY_ONLY=false
PIPELINE_SKIP_DISCOVERY=false

# Fetch and persistence settings.
# PIPELINE_SOURCE: cloudfront, s3, or gateway.
PIPELINE_SOURCE=cloudfront
PIPELINE_WORKERS=20
PIPELINE_RATE_LIMIT=15
PIPELINE_COMMIT_EVERY=200
PIPELINE_NO_LINKS=true
PIPELINE_SHARD=
LOG_LEVEL=INFO

# Storage backend. SQLite remains the default and does not use MYSQL_DSN.
DB_BACKEND=sqlite
MYSQL_DATABASE=cc_links
MYSQL_USER=cc_links
MYSQL_PASSWORD="**PUT_IN_ENV**"
MYSQL_ROOT_PASSWORD="**PUT_IN_ENV**"
MYSQL_DSN="mysql://cc_links:**PUT_IN_ENV**@mysql:3306/cc_links"
MYSQL_CONNECT_RETRIES=30
MYSQL_CONNECT_RETRY_DELAY=2
MYSQL_CONNECT_TIMEOUT=10

# Gateway settings are read only when PIPELINE_SOURCE=gateway.
# URL-encode special characters in the credential before putting it in .env.
GATEWAY_SCHEME=http
GATEWAY_HOST=
GATEWAY_CRED="**PUT_IN_ENV**"
